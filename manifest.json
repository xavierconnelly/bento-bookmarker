{
  "manifest_version": 3,
  "name": "Life Bento Bookmarker",
  "version": "1.0",
  "description": "Save tabs for Life Bento",
  "permissions": ["tabs", "storage", "windows", "sidePanel"],
  "action": {
    "default_title": "Life Bento Bookmarker"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
